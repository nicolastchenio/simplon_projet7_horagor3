# ============================================================
#  HorRAGor — Variables d'environnement (.env.example)
# ============================================================
#  IMPORTANT : Copiez ce fichier en .env AVANT de lancer le projet.
#  Ne JAMAIS commiter le fichier .env réel sur le repository.
#  Assurez-vous que .env figure dans votre .gitignore.
# ============================================================


# ═══════════════════════════════════════════════════════════
#  SECTION 1 — OBLIGATOIRE
# ═══════════════════════════════════════════════════════════
#  Ces variables DOIVENT être remplies avec vos valeurs.
#  Sans elles, l'application ne fonctionnera pas correctement.
# ═══════════════════════════════════════════════════════════

# ── Base de données ──────────────────────────────────────── #
# Connection PostgreSQL (pgvector requis)
# Format : postgresql://[UTILISATEUR]:[MOT-DE-PASSE]@[HOTE]:[PORT]/[BASE]
DATABASE_URL=postgresql://[UTILISATEUR]:[MOT-DE-PASSE]@[HOTE]:[PORT]/[BASE]


# ═══════════════════════════════════════════════════════════
#  SECTION 2 — OPTIONNEL (surcharge)
# ═══════════════════════════════════════════════════════════
#  Ces variables ont des valeurs par défaut dans config.py.
#  Décommentez-les uniquement si vous souhaitez surcharger ces valeurs.
# ═══════════════════════════════════════════════════════════

# ── Ollama — Modèles IA ──────────────────────────────────── #
# (défaut : http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# (défaut : qwen2.5:7b)
# OLLAMA_CHAT_MODEL=qwen2.5:7b

# (défaut : nomic-embed-text)
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── Serveur FastAPI ──────────────────────────────────────── #
# (défaut : 0.0.0.0)
# API_HOST=0.0.0.0

# (défaut : 8000)
# API_PORT=8000

# (défaut : http://localhost:8000)
# API_BASE_URL=http://localhost:8000

# (défaut : 120)
# API_TIMEOUT=120

# (défaut : 60)
# REQUEST_TIMEOUT=60

# ── Recherche wikipedia ──────────────────────────────────────── #
# Timeout pour les app externes (Wikipedia, etc.)
# REQUEST_TIMEOUT=60

# ── Données & Index ──────────────────────────────────────── #
# (défaut : ./data)
# HORRAGOR_DATA_DIR=./data

# (défaut : ./data/faiss_index)
# FAISS_INDEX_DIR=./data/faiss_index

# ── Outils externes ──────────────────────────────────────── #
# (défaut : fr)
# WIKIPEDIA_LANG=fr

# ── Hyper-paramètres RAG ─────────────────────────────────── #
# (défaut : 5)
# FAISS_TOP_K=5

# (défaut : 0.70)
# FAISS_COSINE_THRESHOLD=0.70

# (défaut : 100)
# BATCH_SIZE_PGVECTOR=100

# ── Service interne data-api (Phase 6) ───────────────────── #
# URL du micro-service d'accès aux données PostgreSQL.
# (défaut : http://localhost:8001)
# DATA_API_URL=http://localhost:8001
