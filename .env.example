# ============================================================
#  HorRAGor — Variables d'environnement (.env.example)
# ============================================================
#  IMPORTANT : Copiez ce fichier en .env AVANT de lancer le projet.
#  Ne JAMAIS commiter le fichier .env réel sur le repository.
#  Assurez-vous que .env figure dans votre .gitignore.
# ============================================================


# ═══════════════════════════════════════════════════════════
#  SECTION 1 — OBLIGATOIRE
# ═══════════════════════════════════════════════════════════
#  Ces variables DOIVENT être remplies avec vos valeurs.
#  Sans elles, l'application ne fonctionnera pas correctement.
# ═══════════════════════════════════════════════════════════

# ── Base de données ──────────────────────────────────────── #
# Connection PostgreSQL (pgvector requis)
# Format : postgresql://[UTILISATEUR]:[MOT-DE-PASSE]@[HOTE]:[PORT]/[BASE]
DATABASE_URL=postgresql://[UTILISATEUR]:[MOT-DE-PASSE]@[HOTE]:[PORT]/[BASE]


# ═══════════════════════════════════════════════════════════
#  SECTION 2 — OPTIONNEL (surcharge)
# ═══════════════════════════════════════════════════════════
#  Ces variables ont des valeurs par défaut dans config.py.
#  Décommentez-les uniquement si vous souhaitez surcharger ces valeurs.
# ═══════════════════════════════════════════════════════════

# ── Ollama — Modèles IA ──────────────────────────────────── #
# (défaut : qwen2.5:7b)
# OLLAMA_CHAT_MODEL=qwen2.5:7b

# (défaut : nomic-embed-text)
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Mode LOCAL (hors conteneur, Ollama sur Windows/Mac/Linux) :
# OLLAMA_BASE_URL=http://localhost:11434

# Mode DOCKER (conteneur → hôte Windows/Mac) :
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# Mode DOCKER Linux avancé (si Ollama est aussi conteneurisé) :
# OLLAMA_BASE_URL=http://ollama:11434

# ── Serveur FastAPI ──────────────────────────────────────── #
# (défaut : 0.0.0.0)
# API_HOST=0.0.0.0

# (défaut : 8000)
# API_PORT=8000

# (défaut : http://localhost:8000)
# API_BASE_URL=http://localhost:8000

# (défaut : 120)
# API_TIMEOUT=120

# ── Recherche wikipedia ──────────────────────────────────────── #
# Timeout pour les app externes (Wikipedia, etc.)
# (défaut : 60)
# REQUEST_TIMEOUT=60

# ── Données & Index FAISS ────────────────────────────────── #
# Mode LOCAL (développement natif sur Windows) :
# HORRAGOR_DATA_DIR=./data
# FAISS_INDEX_DIR=./data/faiss_index

# Mode DOCKER (chemin ABSOLU dans l'image, cf Dockerfile) :
# HORRAGOR_DATA_DIR=/app/data
# FAISS_INDEX_DIR=/app/data/faiss_index

# ── Outils externes ──────────────────────────────────────── #
# (défaut : fr)
# WIKIPEDIA_LANG=fr

# ── Hyper-paramètres RAG ─────────────────────────────────── #
# (défaut : 5)
# FAISS_TOP_K=5

# (défaut : 0.70)
# FAISS_COSINE_THRESHOLD=0.70

# (défaut : 100)
# BATCH_SIZE_PGVECTOR=100

# ── Micro-service data-api (Phase 6) ─────────────────────── #
# Côté INTELLIGENCE (URL utilisée par l'API Intelligence pour appeler data-api) :
# Mode LOCAL : DATA_API_URL=http://localhost:8001
# Mode DOCKER (réseau interne) : DATA_API_URL=http://data-api:8001
# DATA_API_URL=http://localhost:8001

# Côté DATA-API (variables internes du service sur le port 8001) :
# DATA_API_HOST=0.0.0.0
# DATA_API_PORT=8001
